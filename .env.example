# Kenya Health Coverage — Environment Variables
# Copy this file to .env and fill in values

# DuckDB database path (relative to project root)
DUCKDB_PATH=data/kenya_health.duckdb

# Data download cache directory
DATA_DIR=data

# World Bank API base URL (no key required)
WB_API_BASE=https://api.worldbank.org/v2

# energydata.info facility CSV URL
FACILITY_CSV_URL=https://energydata.info/dataset/7e456b65-1c58-4031-9a91-397787c1334c/resource/7178b14e-f6fb-4023-8ab2-3fe1ffd7d3ab/download/healthcare_facilities.csv

# GADM Kenya GeoPackage URL
GADM_GPKG_URL=https://geodata.ucdavis.edu/gadm/gadm4.1/gpkg/gadm41_KEN.gpkg

# Coverage buffer radius in degrees (1 degree ~ 111 km)
BUFFER_5KM=0.045
BUFFER_10KM=0.090
BUFFER_15KM=0.135

# Underserved county threshold: facilities per 100k population
UNDERSERVED_THRESHOLD=2.0

# Streamlit server port
STREAMLIT_PORT=8501
